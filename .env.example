# Hermes Engine — Environment Configuration
# Copy to .env and fill in your API keys.

# ── General ──────────────────────────────────────────────────────────
HERMES_DEBUG=false
HERMES_HOST=127.0.0.1
HERMES_PORT=8080

# ── Data paths (default: ~/.hermes-engine) ───────────────────────────
# HERMES_DATA_DIR=/path/to/data
# HERMES_SKILLS_DIR=/path/to/skills
# HERMES_DB_PATH=/path/to/hermes.db

# ── International Provider API Keys (at least one required) ──────────
HERMES_ANTHROPIC_API_KEY=sk-ant-...
# HERMES_ANTHROPIC_BASE_URL=        # optional custom proxy/gateway

HERMES_OPENAI_API_KEY=sk-...
HERMES_GEMINI_API_KEY=...

# ── Anthropic‑compatible proxy / gateway ─────────────────────────────
# HERMES_ANTHROPIC_COMPAT_API_KEY=
# HERMES_ANTHROPIC_COMPAT_BASE_URL=https://your-proxy.example.com
# HERMES_ANTHROPIC_COMPAT_MODEL=claude-sonnet-4-20250514

# ── OpenAI-compatible base URL (optional) ────────────────────────────
# HERMES_OPENAI_BASE_URL=https://api.openai.com/v1

# ── Chinese AI Provider API Keys ─────────────────────────────────────
HERMES_DEEPSEEK_API_KEY=
# HERMES_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

HERMES_MOONSHOT_API_KEY=
# HERMES_MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

HERMES_ZHIPU_API_KEY=
# HERMES_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

HERMES_QWEN_API_KEY=
# HERMES_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

HERMES_XIAOMI_API_KEY=
# HERMES_XIAOMI_BASE_URL=          # required — no default endpoint

HERMES_MINIMAX_API_KEY=
# HERMES_MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ── Curator ──────────────────────────────────────────────────────────
# HERMES_CURATOR_ENABLED=true
# HERMES_CURATOR_INTERVAL_MESSAGES=10
